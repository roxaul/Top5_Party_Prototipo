# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3000

# ─── Banco de dados local (PostgreSQL) ───────────────────────────────────────
# O banco é OPCIONAL. Se não estiver disponível, o jogo roda normalmente
# sem persistência. Copie este arquivo para .env e ajuste os valores.
#
# Setup rápido no Windows:
#   1. Instale PostgreSQL: https://www.postgresql.org/download/windows/
#   2. Abra o pgAdmin ou psql e execute:
#      CREATE DATABASE top5party;
#   3. Preencha as variáveis abaixo e renomeie o arquivo para .env

DB_HOST=localhost
DB_PORT=5432
DB_NAME=top5party
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Banco de dados na nuvem (futuro) ────────────────────────────────────────
# Quando quiser migrar para nuvem, substitua as variáveis DB_* acima
# pela connection string do seu provedor (ex: Supabase, Railway, Neon).
# Exemplo Supabase:
#   DB_HOST=db.xxxx.supabase.co
#   DB_PORT=5432
#   DB_NAME=postgres
#   DB_USER=postgres
#   DB_PASSWORD=sua-senha-aqui
#
# O código (db.js e repository.js) não precisa de nenhuma alteração.
